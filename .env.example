APP_NAME="CBT MTsN 1 Mesuji"
APP_ENV=local
APP_KEY=base64:YourKeyHere
APP_DEBUG=true
APP_URL=http://e-ujian.mtsn1mesuji.sch.id

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
